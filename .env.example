# ─── API Keys ───────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your API keys.
# Only the key for your active provider is required.

# ── DeepSeek (default provider) ─────────────────────────────────────────────
# Platform: https://platform.deepseek.com
# Supported models: deepseek-v4-flash, deepseek-v4-pro
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── Xiaomi MiMo — Token Plan (alternative provider) ─────────────────────────
# Platform:       https://platform.xiaomimimo.com
# Subscription:   https://platform.xiaomimimo.com/#/console/plan-manage
# API Key format: tp-xxxxx  (Token Plan key, different from pay-as-you-go sk-xxxxx)
# Supported models: mimo-v2.5-pro, mimo-v2.5
#
# Token Plan Base URL (OpenAI-compatible, SGP cluster only):
#   SGP: https://token-plan-sgp.xiaomimimo.com/v1
# To switch: set provider="mimo" in .vicorc.json → llm.default
MIMO_API_KEY=your-tp-xxxxx-key-here
