%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e8f4fd', 'primaryTextColor': '#1a1a2e', 'primaryBorderColor': '#2196f3', 'lineColor': '#546e7a', 'secondaryColor': '#f3e5f5', 'tertiaryColor': '#e8f5e9'}}}%%

flowchart TD
    U(["👤 用户输入"])
    REPL["CLI REPL\n/命令分发或进入 AgentLoop"]
    ADD["ContextManager\nadd_user_message()\nmaybe_compress()"]

    subgraph LOOP ["AgentLoop._loop(max_iterations)"]
        direction TB
        LLM["🤖 LLM.stream\nsystem_prompt + messages + tool_defs"]
        CHUNKS["收集 StreamChunk\nText / Reasoning / ToolCall / Done"]
        SAVE["add_assistant_message(text, tool_calls)"]
        HAS_TOOL{"输出了\n工具调用?"}
        HAS_SKILL{"文本包含兼容标签\n<use_skill>?"}
        INJECT["🎯 注入 Skill 正文\nadd_user_message(<skill_instructions>)"]
        AP{"任意工具\n需要审批?"}
        SEQ["🔒 串行执行\n逐个弹确认框"]
        PAR["⚡ asyncio.gather\n并发执行自动批准工具"]
        TR["add_tool_result() × N\nmaybe_compress()"]
        DONE["✅ 输出最终回复"]
    end

    U --> REPL
    REPL --> ADD
    ADD --> LLM
    LLM --> CHUNKS
    CHUNKS --> SAVE
    SAVE --> HAS_TOOL
    HAS_TOOL -- "无" --> HAS_SKILL
    HAS_SKILL -- "是" --> INJECT
    INJECT --> LLM
    HAS_SKILL -- "否" --> DONE
    HAS_TOOL -- "有" --> AP
    AP -- "是" --> SEQ
    AP -- "否" --> PAR
    SEQ --> TR
    PAR --> TR
    TR --> LLM

    style U fill:#fff9c4,stroke:#f9a825,color:#1a1a2e
    style LLM fill:#e3f2fd,stroke:#1565c0,color:#1a1a2e
    style PAR fill:#e8f5e9,stroke:#2e7d32,color:#1a1a2e
    style SEQ fill:#fff3e0,stroke:#e65100,color:#1a1a2e
    style INJECT fill:#f3e5f5,stroke:#9c27b0,color:#1a1a2e
    style DONE fill:#e8f5e9,stroke:#2e7d32,color:#1a1a2e
